# À définir via : supabase secrets set --env-file .env
# (ne jamais committer le vrai fichier .env dans Git)

SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# Secret que vous choisissez vous-même, à réutiliser dans vos appels à generate-key
ADMIN_SECRET=changez-moi-en-quelque-chose-de-long-et-aleatoire

# Optionnel : pour l'envoi automatique de l'email contenant la clé
RESEND_API_KEY=
